# ─────────────────────────────────────────────────────────────────────────────
# DermAI Platform — Environment Configuration
# Copy this file to .env and adjust values for your environment.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Project ───────────────────────────────────────────────────────────────────
PROJECT_NAME="DermAI — Skin Lesion Analysis Platform"
VERSION="2.0.0"
MODEL_VERSION="unetpp-efficientnetb2-v1"

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── AI / Inference ────────────────────────────────────────────────────────────
SEGMENTATION_INPUT_SIZE=256
SEGMENTATION_THRESHOLD=0.5
CLASSIFICATION_INPUT_SIZE=224
TOP_K_PREDICTIONS=5
NUM_CLASSES=7
ROI_PADDING_RATIO=0.04

# Temperature scaling: T > 1 reduces overconfidence (recommended: 1.2–1.5)
# Set to 1.0 to disable calibration entirely.
TEMPERATURE_SCALING=1.3

# Confidence tier thresholds (post-calibration)
CONFIDENCE_HIGH=0.75
CONFIDENCE_MEDIUM=0.45

# ── API ───────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20
# Comma-separated allowed origins (JSON list format)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Model paths (override if models are stored elsewhere) ────────────────────
# SEGMENTATION_MODEL_PATH=/path/to/best_model.pth
# CLASSIFICATION_MODEL_PATH=/path/to/classifier.pth
